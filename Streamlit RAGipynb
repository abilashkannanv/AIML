        "if 'total_embedding_tokens' not in st.session_state:\n",
        "    st.session_state['total_embedding_tokens'] = 0\n",
        "if 'logs' not in st.session_state:\n",
        "    st.session_state['logs'] = []\n",
        "\n",
        "def add_log_entry(tool_used: str, query: str, response: str, time_taken: float, guardrail_triggered: bool = False):\n",
        "    st.session_state.logs.append({\n",
        "        \"timestamp\": time.strftime(\"%Y-%m-%d %H:%M:%S\"),\n",
        "        \"tool_used\": tool_used,\n",
        "        \"query\": query,\n",
        "        \"response\": response,\n",
        "        \"time_taken\": f\"{time_taken:.2f} seconds\",\n",
        "        \"guardrail_triggered\": guardrail_triggered\n",
        "    })\n",
        "\n",
        "\n",
        "# --- Define Tool Functions (moved from main Streamlit app flow) ---\n",
        "class RAGRetrieverInput(BaseModel):\n",
        "    query: str = Field(description=\"The user's query to answer.\")\n",
        "\n",
        "def _run_rag_retriever(query: str) -> str:\n",
        "    \"\"\"Answers a general query about the loaded documents without specific file or elaboration requirements. Use this for standard information retrieval.\"\"\"\n",
        "    start_time = time.time()\n",
        "    guardrail_triggered = False\n",
        "    response_text = \"\"\n",
        "    if st.session_state['vector_store_built'] and st.session_state['vector_store'] is not None:\n",
        "        llm = ChatOpenAI(model_name=\"gpt-3.5-turbo\", temperature=0)\n",
        "        qa_chain = RetrievalQA.from_chain_type(\n",
        "            llm=llm,\n",
        "            chain_type=\"stuff\",\n",
        "            retriever=st.session_state['vector_store'].as_retriever()\n",
        "        )\n",
        "        response = qa_chain.run(query)\n",
        "        if check_for_banned_keywords(response):\n",
        "            response_text = \"Output generation stopped due to policy violation (guardrail triggered).\"\n",
        "            guardrail_triggered = True\n",
        "        else:\n",
        "            response_text = f\"Tool Used: RAG Retriever Tool\\nAnswer: {response}\"\n",
        "    else:\n",
        "        response_text = \"Vector store not built. Cannot run RAG Retriever.\"\n",
        "    end_time = time.time()\n",
        "    add_log_entry(\"RAG Retriever Tool\", query, response_text, end_time - start_time, guardrail_triggered)\n",
        "    return response_text\n",
        "\n",
        "class ElaboratorInput(BaseModel):\n",
        "    query: str = Field(description=\"The user's query that needs to be elaborated.\")\n",
        "\n",
        "def _run_elaborator(query: str) -> str:\n",
        "    \"\"\"Expands or rephrases a user's query to make it more detailed and comprehensive for better RAG performance. Use this tool if the user explicitly asks for a 'detailed', 'careful', or 'thorough' answer, or if the query itself is vague and could benefit from expansion.\"\"\"\n",
        "    start_time = time.time()\n",
        "    guardrail_triggered = False\n",
        "    response_text = \"\"\n",
        "    llm = ChatOpenAI(model_name=\"gpt-3.5-turbo\", temperature=0)\n",
        "    prompt_template = ChatPromptTemplate.from_messages([\n",
        "        (\"system\", \"You are a helpful assistant that elaborates user queries to make them more precise and comprehensive for a retrieval augmented generation system. Provide a rephrased or expanded version of the user's query.\"),\n",
        "        (\"user\", \"{query}\")\n",
        "    ])\n",
        "    elaborator_chain = prompt_template | llm\n",
        "    elaborated_query = elaborator_chain.invoke({\"query\": query}).content\n",
        "    if check_for_banned_keywords(elaborated_query):\n",
        "        response_text = \"Output generation stopped due to policy violation (guardrail triggered).\"\n",
        "        guardrail_triggered = True\n",
        "    else:\n",
        "        response_text = f\"Tool Used: Elaborator Tool\\nElaborated Query: {elaborated_query}\"\n",
        "    end_time = time.time()\n",
        "    add_log_entry(\"Elaborator Tool\", query, response_text, end_time - start_time, guardrail_triggered)\n",
        "    return response_text\n",
        "\n",
        "class FilterToolInput(BaseModel):\n",
