        "from langchain_core.documents import Document\n",
        "from langchain_community.embeddings import OpenAIEmbeddings\n",
        "from langchain_community.vectorstores import FAISS\n",
        "import pickle\n",
        "import tiktoken\n",
        "\n",
        "# Load environment variables\n",
        "_ = load_dotenv(find_dotenv())\n",
        "\n",
        "# Set OpenAI API key\n",
        "# The user provided a specific API key format, I will use that.\n",
        "os.environ[\"OPENAI_API_KEY\"] = \"voc-262423617156170395256969020d2c765580.35946547\"\n",
        "\n",
        "# Define the directory where the documents are located\n",
        "DOCS_DIR = '/content/'\n",
        "FAISS_INDEX_PATH = 'faiss_index.pkl'\n",
        "\n",
        "def load_documents(directory):\n",
        "    documents = []\n",
        "    loaded_files_info = []\n",
        "    for filename in os.listdir(directory):\n",
        "        filepath = os.path.join(directory, filename)\n",
        "        if os.path.isfile(filepath):\n",
        "            doc_metadata = {'filename': filename}\n",
        "            try:\n",
        "                if filename.endswith('.pdf'):\n",
        "                    loader = PyPDFLoader(filepath)\n",
        "                    docs = loader.load()\n",
        "                    # PyPDFLoader often returns a list of documents (one per page)\n",
        "                    # We'll add page metadata here if available\n",
        "                    for i, doc in enumerate(docs):\n",
        "                        # Ensure metadata is a dictionary before updating\n",
        "                        if not isinstance(doc.metadata, dict):\n",
        "                            doc.metadata = {}\n",
        "                        doc.metadata.update(doc_metadata)\n",
        "                        doc.metadata['page'] = i + 1 # Page numbers are 1-indexed\n",
        "                        documents.append(doc)\n",
        "\n",
        "                elif filename.endswith(('.txt', '.md')):\n",
        "                    loader = TextLoader(filepath)\n",
        "                    docs = loader.load()\n",
        "                    for doc in docs:\n",
        "                        if not isinstance(doc.metadata, dict):\n",
        "                            doc.metadata = {}\n",
        "                        doc.metadata.update(doc_metadata)\n",
        "                        documents.append(doc)\n",
        "                else:\n",
        "                    continue # Skip other file types\n",
        "\n",
        "                # Calculate word count for the file\n",
        "                file_word_count = sum(len(doc.page_content.split()) for doc in docs)\n",
        "                loaded_files_info.append({\n",
        "                    'filename': filename,\n",
        "                    'word_count': file_word_count\n",
        "                })\n",
        "\n",
        "            except Exception as e:\n",
        "                st.warning(f\"Could not load {filename}: {e}\")\n",
        "    return documents, loaded_files_info\n",
        "\n",
        "def chunk_documents(documents, strategy, chunk_size, chunk_overlap):\n",
        "    if strategy == \"Recursive\":\n",
        "        text_splitter = RecursiveCharacterTextSplitter(\n",
        "            chunk_size=chunk_size,\n",
        "            chunk_overlap=chunk_overlap,\n",
        "            length_function=len\n",
        "        )\n",
        "    elif strategy == \"Paragraph\":\n",
        "        text_splitter = CharacterTextSplitter(\n",
        "            separator=\"\\n\\n\", # Split by paragraphs\n",
        "            chunk_size=chunk_size,\n",
        "            chunk_overlap=chunk_overlap,\n",
        "            length_function=len\n",
        "        )\n",
        "    elif strategy == \"Fixed-size\":\n",
        "        text_splitter = CharacterTextSplitter(\n",
        "            separator=\"\", # Split by fixed size characters\n",
        "            chunk_size=chunk_size,\n",
        "            chunk_overlap=chunk_overlap,\n",
        "            length_function=len\n",
        "        )\n",
        "    else:\n",
        "        st.error(\"Invalid chunking strategy selected.\")\n",
        "        return []\n",
        "\n",
        "    chunks = text_splitter.split_documents(documents)\n",
        "    return chunks\n",
        "\n",
        "def get_token_count(text):\n",
        "    encoding = tiktoken.encoding_for_model(\"gpt-3.5-turbo\") # Using a common encoding model\n",
        "    return len(encoding.encode(text))\n",
        "\n",
        "# --- Streamlit Application ---\n",
        "st.set_page_config(layout=\"wide\", page_title=\"Intelligent RAG System\")\n",
        "st.title(\"Intelligent RAG System with Streamlit\")\n",
        "\n",
        "# --- File Loading and Metadata Extraction ---\n",
        "st.header(\"1. Document Loading and Metadata\")\n",
        "\n",
        "# Load documents from the specified directory\n",
        "documents, loaded_files_info = load_documents(DOCS_DIR)\n",
        "\n",
        "if loaded_files_info:\n",
        "    st.write(\"**Files Loaded:**\")\n",
        "    for file_info in loaded_files_info:\n",
        "        st.write(f\"- {file_info['filename']} (Word Count: {file_info['word_count']})\")\n",
        "else:\n",
        "    st.warning(\"No documents loaded from the /content/ directory. Please ensure files are in the /content/ directory.\")\n",
        "\n",
        "# Display overall document count and a sample\n",
        "st.write(f\"Total documents (pages/sections) loaded: {len(documents)}\")\n",
        "if documents:\n",
        "    st.subheader(\"Sample Document Metadata:\")\n",
        "    st.json(documents[0].metadata)\n",
        "    st.text_area(\"Sample Document Content (first 200 chars):\", documents[0].page_content[:200], height=100)\n",
        "\n",
        "# --- Chunking Strategy Controls ---\n",
        "st.sidebar.header(\"Chunking Strategy\")\n",
        "chunk_strategy = st.sidebar.selectbox(\n",
        "    \"Select Chunking Strategy:\",\n",
        "    (\"Recursive\", \"Paragraph\", \"Fixed-size\")\n",
        ")\n",
        "chunk_size = st.sidebar.slider(\n",
        "    \"Chunk Size:\",\n",
        "    min_value=100,\n",
        "    max_value=2000,\n",
        "    value=1000,\n",
        "    step=50\n",
        ")\n",
        "chunk_overlap = st.sidebar.slider(\n",
        "    \"Chunk Overlap:\",\n",
        "    min_value=0,\n",
        "    max_value=chunk_size - 1,\n",
        "    value=200,\n",
        "    step=10\n",
        ")\n",
        "\n",
        "st.header(\"2. Chunking Strategy and Preview\")\n",
        "chunks = []\n",
        "if documents:\n",
        "    st.write(f\"Applying '{chunk_strategy}' strategy with chunk size {chunk_size} and overlap {chunk_overlap}.\")\n",
        "    chunks = chunk_documents(documents, chunk_strategy, chunk_size, chunk_overlap)\n",
        "    st.write(f\"Total chunks generated: {len(chunks)}\")\n",
        "\n",
        "    if chunks:\n",
        "        st.subheader(\"Preview of Chunks:\")\n",
        "        num_preview_chunks = st.slider(\"Number of chunks to preview:\", 1, min(10, len(chunks)), 3)\n",
        "        for i in range(num_preview_chunks):\n",
        "            st.markdown(f\"**Chunk {i+1}**\")\n",
        "            st.json(chunks[i].metadata)\n",
        "            st.text_area(f\"Content of Chunk {i+1}:\", chunks[i].page_content, height=150, key=f\"chunk_preview_{i}\")\n",
        "    else:\n",
        "        st.warning(\"No chunks generated. Please check your documents or chunking parameters.\")\n",
        "else:\n",
        "    st.info(\"Load documents first to enable chunking.\")\n",
        "\n",
        "# --- Embedding and Vector Store ---\n",
        "st.header(\"3. Embedding and Vector Store\")\n",
        "\n",
        "if chunks:\n",
        "    if st.button(\"Embed Chunks and Build Vector Store\"):\n",
        "        with st.spinner(\"Embedding chunks and building FAISS index...\"):\n",
        "            try:\n",
        "                # Initialize OpenAI Embeddings with the specified model\n",
        "                embeddings_model = OpenAIEmbeddings(model=\"text-embedding-3-small\")\n",
        "\n",
        "                # Build FAISS vector store\n",
        "                vector_store = FAISS.from_documents(chunks, embeddings_model)\n",
        "\n",
        "                # Persist the vector store\n",
        "                with open(FAISS_INDEX_PATH, \"wb\") as f:\n",
        "                    pickle.dump(vector_store, f)\n",
        "\n",
        "                st.session_state['vector_store_built'] = True\n",
        "                st.session_state['num_vectors'] = len(chunks)\n",
        "\n",
        "                total_tokens = sum(get_token_count(chunk.page_content) for chunk in chunks)\n",
        "                st.session_state['total_embedding_tokens'] = total_tokens\n",
        "\n",
        "                st.success(\"FAISS vector store built and persisted successfully!\")\n",
        "\n",
        "            except Exception as e:\n",
        "                st.error(f\"Error building vector store: {e}\")\n",
        "\n",
        "    if st.session_state.get('vector_store_built'):\n",
        "        st.subheader(\"Embedding Summary:\")\n",
        "        st.write(f\"Number of vectors (chunks embedded): {st.session_state.get('num_vectors', 0)}\")\n",
        "        st.write(f\"Total tokens embedded: {st.session_state.get('total_embedding_tokens', 0)}\")\n",
        "\n",
        "        st.subheader(\"Vector Store Status:\")\n",
        "        st.success(f\"FAISS vector store available at: {FAISS_INDEX_PATH}\")\n",
        "else:\n",
        "    st.info(\"Please ensure documents are loaded and chunked before embedding.\")\n",
        "\n",
