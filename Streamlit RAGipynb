        "%%writefile tools.py\n",
        "import os\n",
        "import time\n",
        "import pickle\n",
        "import tiktoken\n",
        "from typing import Optional\n",
        "\n",
        "from langchain_community.embeddings import OpenAIEmbeddings\n",
        "from langchain_community.vectorstores import FAISS\n",
        "from langchain_community.chat_models import ChatOpenAI\n",
        "from langchain.chains import RetrievalQA\n",
        "from langchain_core.prompts import ChatPromptTemplate\n",
        "from langchain.pydantic_v1 import BaseModel, Field\n",
        "\n",
        "# Import from safety_guard.py\n",
        "from safety_guard import BANNED_KEYWORDS, check_for_banned_keywords\n",
        "\n",
        "# --- Configuration and Helpers (adapted for standalone use) ---\n",
        "\n",
        "# Set OpenAI API key (replace with your actual key or load from .env)\n",
        "os.environ[\"OPENAI_API_KEY\"] = \"voc-262423617156170395256969020d2c765580.35946547\"\n",
        "\n",
        "FAISS_INDEX_PATH = 'faiss_index.pkl' # Ensure this path is correct if loading an index\n",
        "\n",
        "def add_log_entry(tool_used: str, query: str, response: str, time_taken: float, guardrail_triggered: bool = False):\n",
        "    \"\"\"Placeholder for logging. In a Streamlit app, this would update st.session_state.logs.\"\"\"\n",
        "    # print(f\"[LOG] Timestamp: {time.strftime(\"%Y-%m-%d %H:%M:%S\")}\")\n",
        "    # print(f\"[LOG] Tool Used: {tool_used}\")\n",
        "    # print(f\"[LOG] Query: {query}\")\n",
        "    # print(f\"[LOG] Response/Outcome: {response}\")\n",
        "    # print(f\"[LOG] Time Taken: {time_taken:.2f} seconds\")\n",
        "    # if guardrail_triggered:\n",
        "    #     print(\"[LOG] Guardrail Triggered!\")\n",
        "    pass # Suppress output for this standalone file\n",
        "\n",
        "def get_token_count(text):\n",
        "    encoding = tiktoken.encoding_for_model(\"gpt-3.5-turbo\")\n",
        "    return len(encoding.encode(text))\n",
        "\n",
        "def load_vector_store(path, embeddings_model):\n",
        "    if os.path.exists(path):\n",
        "        try:\n",
        "            with open(path, \"rb\") as f:\n",
        "                return pickle.load(f)\n",
        "        except Exception as e:\n",
        "            print(f\"Error loading vector store: {e}\") # Use print for standalone\n",
        "    return None\n",
        "\n",
        "# --- Tool Definitions ---\n",
        "\n",
        "class RAGRetrieverInput(BaseModel):\n",
        "    query: str = Field(description=\"The user's query to answer.\")\n",
        "\n",
        "def _run_rag_retriever(query: str) -> str:\n",
        "    \"\"\"Answers a general query about the loaded documents without specific file or elaboration requirements. Use this for standard information retrieval.\"\"\"\n",
        "    start_time = time.time()\n",
        "    guardrail_triggered = False\n",
        "    response_text = \"\"\n",
        "\n",
        "    # Load vector store within the tool if not passed, or from a global/module variable\n",
        "    embeddings_model = OpenAIEmbeddings(model=\"text-embedding-3-small\") # Re-initialize if necessary\n",
        "    vector_store = load_vector_store(FAISS_INDEX_PATH, embeddings_model) # Load or get the store\n",
        "\n",
        "    if vector_store is not None:\n",
        "        llm = ChatOpenAI(model_name=\"gpt-3.5-turbo\", temperature=0)\n",
        "        qa_chain = RetrievalQA.from_chain_type(\n",
        "            llm=llm,\n",
        "            chain_type=\"stuff\",\n",
        "            retriever=vector_store.as_retriever()\n",
        "        )\n",
        "        try:\n",
        "            response = qa_chain.run(query)\n",
        "            if check_for_banned_keywords(response):\n",
        "                response_text = \"Output generation stopped due to policy violation (guardrail triggered).\"\n",
        "                guardrail_triggered = True\n",
        "            else:\n",
        "                response_text = f\"Tool Used: RAG Retriever Tool\\nAnswer: {response}\"\n",
        "        except Exception as e:\n",
        "            response_text = f\"Error running RAG Retriever: {e}\"\n",
        "    else:\n",
        "        response_text = \"Vector store not built or found. Cannot run RAG Retriever.\"\n",
        "\n",
        "    end_time = time.time()\n",
        "    add_log_entry(\"RAG Retriever Tool\", query, response_text, end_time - start_time, guardrail_triggered)\n",
        "    return response_text\n",
        "\n",
        "class ElaboratorInput(BaseModel):\n",
        "    query: str = Field(description=\"The user's query that needs to be elaborated.\")\n",
        "\n",
        "def _run_elaborator(query: str) -> str:\n",
        "    \"\"\"Expands or rephrases a user's query to make it more detailed and comprehensive for better RAG performance. Use this tool if the user explicitly asks for a 'detailed', 'careful', or 'thorough' answer, or if the query itself is vague and could benefit from expansion.\"\"\"\n",
        "    start_time = time.time()\n",
        "    guardrail_triggered = False\n",
        "    response_text = \"\"\n",
        "\n",
        "    llm = ChatOpenAI(model_name=\"gpt-3.5-turbo\", temperature=0)\n",
        "    prompt_template = ChatPromptTemplate.from_messages([\n",
        "        (\"system\", \"You are a helpful assistant that elaborates user queries to make them more precise and comprehensive for a retrieval augmented generation system. Provide a rephrased or expanded version of the user's query.\"),\n",
        "        (\"user\", \"{query}\")\n",
        "    ])\n",
        "    elaborator_chain = prompt_template | llm\n",
        "    try:\n",
        "        elaborated_query = elaborator_chain.invoke({\"query\": query}).content\n",
        "        if check_for_banned_keywords(elaborated_query):\n",
        "            response_text = \"Output generation stopped due to policy violation (guardrail triggered).\"\n",
        "            guardrail_triggered = True\n",
        "        else:\n",
        "            response_text = f\"Tool Used: Elaborator Tool\\nElaborated Query: {elaborated_query}\"\n",
        "    except Exception as e:\n",
        "        response_text = f\"Error running Elaborator: {e}\"\n",
        "\n",
        "    end_time = time.time()\n",
        "    add_log_entry(\"Elaborator Tool\", query, response_text, end_time - start_time, guardrail_triggered)\n",
        "    return response_text\n",
        "\n",
        "class FilterToolInput(BaseModel):\n",
        "    query: str = Field(description=\"The core question to answer.\")\n",
        "    filename: Optional[str] = Field(None, description=\"The filename to filter by (e.g., 'ML.pdf'). Extract this from 'file:FILENAME' or 'from FILENAME' in the query.\")\n",
        "    page: Optional[int] = Field(None, description=\"The page number to filter by (e.g., 5). Extract this if mentioned as 'page:NUMBER' in the query.\")\n",
        "\n",
        "def _run_filter_rag(query: str, filename: Optional[str] = None, page: Optional[int] = None) -> str:\n",
        "    \"\"\"Answers a query using RAG, but filters the retrieved documents by filename and/or page number. Use this tool if the user's query specifies a particular 'file:' or 'from FILENAME' and/or a 'page:NUMBER'. The filename should be extracted from the query as 'file:FILENAME' or 'from FILENAME'. The page number should be extracted from the query as 'page:NUMBER'.\"\"\"\n",
        "    start_time = time.time()\n",
        "    guardrail_triggered = False\n",
        "    response_text = \"\"\n",
        "\n",
        "    embeddings_model = OpenAIEmbeddings(model=\"text-embedding-3-small\") # Re-initialize if necessary\n",
        "    vector_store = load_vector_store(FAISS_INDEX_PATH, embeddings_model) # Load or get the store\n",
        "\n",
        "    if vector_store is not None:\n",
        "        llm = ChatOpenAI(model_name=\"gpt-3.5-turbo\", temperature=0)\n",
        "        search_filters = {}\n",
        "        if filename:\n",
        "            search_filters['filename'] = filename\n",
        "        if page is not None and page > 0:\n",
        "            search_filters['page'] = page\n",
        "\n",
        "        if search_filters:\n",
        "            retriever = vector_store.as_retriever(\n",
        "                search_kwargs={'filter': search_filters}\n",
        "            )\n",
        "            filter_info = f\" (Filtered by: {search_filters})\"\n",
        "        else:\n",
        "            retriever = vector_store.as_retriever()\n",
        "            filter_info = \" (No filters applied)\"\n",
        "\n",
        "        qa_chain = RetrievalQA.from_chain_type(\n",
        "            llm=llm,\n",
        "            chain_type=\"stuff\",\n",
        "            retriever=retriever\n",
        "        )\n",
        "        try:\n",
        "            response = qa_chain.run(query)\n",
        "            if check_for_banned_keywords(response):\n",
        "                response_text = \"Output generation stopped due to policy violation (guardrail triggered).\"\n",
        "                guardrail_triggered = True\n",
        "            else:\n",
        "                response_text = f\"Tool Used: Filter Tool{filter_info}\\nAnswer: {response}\"\n",
        "        except Exception as e:\n",
        "            response_text = f\"Error running Filter Tool: {e}\"\n",
        "    else:\n",
        "        response_text = \"Vector store not built or found. Cannot run Filter Tool.\"\n",
        "\n",
        "    end_time = time.time()\n",
        "    add_log_entry(\"Filter Tool\", query, response_text, end_time - start_time, guardrail_triggered)\n",
        "    return response_text\n"
